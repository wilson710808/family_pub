# 環境變數配置範例

# ===========================================
# AI API 配置 (必要)
# ===========================================
# NVIDIA NIM API (免費申請: https://build.nvidia.com)
OPENAI_API_KEY=nvapi-xxx
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_MODEL=meta/llama-3.1-405b-instruct

# ===========================================
# 股價 API 配置 (選填)
# ===========================================
# Alpha Vantage (免費申請: https://www.alphavantage.co)
# 每日 500 次免費調用
ALPHA_VANTAGE_KEY=demo

# ===========================================
# 服務配置
# ===========================================
PORT=3001
